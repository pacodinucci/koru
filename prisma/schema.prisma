generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String
  role          UserRole  @default(PARENT)
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  blogLikes     BlogPostLike[]
  createdCalendarEvents CalendarEvent[] @relation("CalendarEventCreator")
  calendarEventAudiences CalendarEventAudience[]
  createdInvitations UserInvitation[] @relation("UserInvitationsCreated")
  teacherProfile TeacherProfile?
  studentGuardianLinks StudentGuardian[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BlockType {
  HERO
  RICH_TEXT
  CTA
  IMAGE
  DONATION
}

enum DonationProvider {
  MERCADO_PAGO
  STRIPE
  PAYPAL
}

enum DonationStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELED
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
}

enum BlogPostVisibility {
  PUBLIC
  MEMBERS
}

enum BlogTagType {
  GROUP
  CUSTOM
}

enum ContactMessageStatus {
  NEW
  READ
  REPLIED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum UserRole {
  ADMIN
  TEACHER
  PARENT
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
}

enum StudentGuardianRelationship {
  MOTHER
  FATHER
  TUTOR
  GUARDIAN
  OTHER
}

enum CalendarEventStatus {
  DRAFT
  PUBLISHED
  CANCELED
}

enum CalendarAudienceType {
  ALL
  TEACHERS
  PARENTS
  PRIVATE
}

enum CalendarEventKind {
  EVENT
  MEETING
}

enum ExamStatus {
  DRAFT
  PUBLISHED
}

model Page {
  id             String      @id @default(cuid())
  slug           String      @unique
  title          String
  status         PageStatus  @default(DRAFT)
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?
  blocks         PageBlock[]
  donations      Donation[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model PageBlock {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      BlockType
  order     Int
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pageId, order])
  @@index([pageId, type])
}

model Donation {
  id              String           @id @default(cuid())
  provider        DonationProvider
  providerRef     String?          @unique
  amount          Decimal          @db.Decimal(10, 2)
  currency        String           @default("ARS")
  donorName       String?
  donorEmail      String?
  status          DonationStatus   @default(PENDING)
  pageId          String?
  page            Page?            @relation(fields: [pageId], references: [id], onDelete: SetNull)
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  completedAt     DateTime?
}

model CmsTextEntry {
  key            String   @id
  draftValue     String
  publishedValue String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model BlogPost {
  id            String             @id @default(cuid())
  slug          String             @unique
  title         String
  excerpt       String
  content       String
  contentBlocks Json?
  status        BlogPostStatus     @default(DRAFT)
  visibility    BlogPostVisibility @default(PUBLIC)
  authorName    String?
  publishedAt   DateTime?
  comments      BlogComment[]
  likes         BlogPostLike[]
  tags          BlogPostTag[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([status, publishedAt])
  @@index([status, visibility, publishedAt])
}

model BlogTag {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  type      BlogTagType   @default(CUSTOM)
  groupId   String?
  group     StudentGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  posts     BlogPostTag[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([type])
  @@index([groupId])
}

model BlogPostTag {
  postId String
  tagId  String
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}

model BlogPostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId, createdAt])
}

model BlogComment {
  id          String   @id @default(cuid())
  postId       String
  post         BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorName   String
  authorEmail  String?
  content      String
  approved     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([postId, approved, createdAt])
}

model ContactMessage {
  id        String               @id @default(cuid())
  nombre    String
  email     String
  telefono  String?
  mensaje   String
  status    ContactMessageStatus @default(NEW)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([status, createdAt])
}

model UserInvitation {
  id          String           @id @default(cuid())
  email       String
  role        UserRole         @default(PARENT)
  status      InvitationStatus @default(PENDING)
  invitedById String?
  invitedBy   User?            @relation("UserInvitationsCreated", fields: [invitedById], references: [id], onDelete: SetNull)
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([email])
  @@index([status, createdAt])
  @@index([invitedById])
}

model StudentGroup {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  ageRange    String
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  students    Student[]
  teacherResponsibilities StudentGroupTeacher[]
  exams       Exam[]
  blogTags    BlogTag[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive, sortOrder])
}

model TeacherProfile {
  id          String    @id @default(cuid())
  userId      String?   @unique
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  displayName String
  email       String?
  phone       String?
  bio         String?
  isActive    Boolean   @default(true)
  groupResponsibilities StudentGroupTeacher[]
  exams       Exam[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive, displayName])
  @@index([email])
}

model StudentGroupTeacher {
  id        String         @id @default(cuid())
  groupId   String
  group     StudentGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([groupId, teacherId])
  @@index([groupId])
  @@index([teacherId])
}

model Student {
  id               String            @id @default(cuid())
  firstName        String
  lastName         String
  birthDate        DateTime
  groupId          String
  group            StudentGroup      @relation(fields: [groupId], references: [id], onDelete: Restrict)
  status           StudentStatus     @default(ACTIVE)
  notes            String?
  guardians        StudentGuardian[]
  examGrades       ExamGrade[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([groupId, status])
  @@index([lastName, firstName])
}

model Exam {
  id          String         @id @default(cuid())
  groupId     String
  group       StudentGroup   @relation(fields: [groupId], references: [id], onDelete: Restrict)
  teacherId   String
  teacher     TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  title       String
  subject     String?
  examDate    DateTime
  description String?
  status      ExamStatus     @default(DRAFT)
  grades      ExamGrade[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([groupId, examDate])
  @@index([teacherId, examDate])
  @@index([status, examDate])
}

model ExamGrade {
  id           String   @id @default(cuid())
  examId       String
  exam         Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  score        Decimal  @db.Decimal(5, 2)
  observations String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([examId, studentId])
  @@index([studentId])
}

model StudentGuardian {
  id               String                      @id @default(cuid())
  studentId        String
  student          Student                     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  userId           String?
  user             User?                       @relation(fields: [userId], references: [id], onDelete: SetNull)
  email            String
  relationship     StudentGuardianRelationship @default(GUARDIAN)
  isPrimary        Boolean                     @default(false)
  canPickup        Boolean                     @default(false)
  emergencyContact Boolean                     @default(false)
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  @@unique([studentId, email])
  @@index([userId])
  @@index([email])
}

model CalendarEvent {
  id           String                @id @default(cuid())
  title        String
  description  String?
  startsAt     DateTime
  endsAt       DateTime
  allDay       Boolean               @default(false)
  location     String?
  status       CalendarEventStatus   @default(DRAFT)
  audienceType CalendarAudienceType  @default(ALL)
  kind         CalendarEventKind     @default(EVENT)
  createdById  String
  createdBy    User                  @relation("CalendarEventCreator", fields: [createdById], references: [id], onDelete: Restrict)
  audiences    CalendarEventAudience[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([startsAt, endsAt])
  @@index([status, audienceType])
}

model CalendarEventAudience {
  id        String        @id @default(cuid())
  eventId   String
  event     CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}
